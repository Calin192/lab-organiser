<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane stylesheets="@register.css"
           styleClass="root"
           minHeight="300.0"
           minWidth="500.0"
           prefHeight="600.0"
           prefWidth="1000.0"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.laborganiser.frontend.auth.RegisterController">

    <children>

        <VBox fx:id="vbox"
              alignment="CENTER"
              spacing="5.0"
              styleClass="card"
              prefWidth="666.0"
              prefHeight="581.0"
              maxWidth="666.0"
              maxHeight="581.0">

            <children>

                <HBox prefWidth="385" maxWidth="385" alignment="CENTER_LEFT">
                    <children>
                        <Button text="← Back"
                                onAction="#onBackToLoginClicked"
                                styleClass="back-button"/>
                    </children>
                </HBox>

                <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                    <image>
                        <Image url="@/Images/flask 1.png"/>
                    </image>
                </ImageView>

                <Label text="Register to Larp Organiser"
                       styleClass="title"/>

                <Label text="Email"
                       prefWidth="385"
                       maxWidth="385"
                       alignment="CENTER_LEFT"
                       styleClass="small-label"/>

                <TextField fx:id="username"
                           promptText="john.doe@gmail.com"
                           styleClass="input"
                           maxWidth="385.0"
                           prefHeight="40.0"/>

                <Label maxHeight="10" prefHeight="10"/>

                <Label text="Password"
                       prefWidth="385"
                       maxWidth="385"
                       alignment="CENTER_LEFT"
                       styleClass="small-label"/>

                <StackPane alignment="CENTER"
                           prefWidth="385"
                           maxWidth="385">

                    <PasswordField fx:id="password"
                                   promptText="*********"
                                   styleClass="input"
                                   prefWidth="385"
                                   maxWidth="385"
                                   prefHeight="40.0"/>

                    <TextField fx:id="visiblePasswordField"
                               promptText="*********"
                               styleClass="input"
                               prefWidth="385"
                               maxWidth="385"
                               prefHeight="40.0"
                               visible="false"
                               managed="false"/>

                    <Button onAction="#togglePassword"
                            StackPane.alignment="CENTER_RIGHT"
                            styleClass="inside-button">

                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                <image>
                                    <Image url="@/Images/visibility.png"/>
                                </image>
                            </ImageView>
                        </graphic>

                    </Button>

                </StackPane>

                <Label text="Confirm Password"
                       prefWidth="385"
                       maxWidth="385"
                       alignment="CENTER_LEFT"
                       styleClass="small-label"/>

                <StackPane alignment="CENTER"
                           prefWidth="385"
                           maxWidth="385">

                    <PasswordField fx:id="passwordConfirm"
                                   promptText="*********"
                                   styleClass="input"
                                   prefWidth="385"
                                   maxWidth="385"
                                   prefHeight="40.0"/>

                    <TextField fx:id="visiblePasswordConfirm"
                               promptText="*********"
                               styleClass="input"
                               prefWidth="385"
                               maxWidth="385"
                               prefHeight="40.0"
                               visible="false"
                               managed="false"/>

                    <Button onAction="#togglePassword"
                            StackPane.alignment="CENTER_RIGHT"
                            styleClass="inside-button">

                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                <image>
                                    <Image url="@/Images/visibility.png"/>
                                </image>
                            </ImageView>
                        </graphic>

                    </Button>

                </StackPane>

                <Label maxHeight="10" prefHeight="10"/>

                <Button fx:id="registerButton"
                        text="Register"
                        mnemonicParsing="false"
                        onAction="#onRegisterClick"
                        styleClass="primary-button"
                        prefWidth="385.0"
                        prefHeight="40.0"/>

            </children>

        </VBox>

        <Label fx:id="onRegisterFailed"
               text="Register failed. Please check your credentials and try again."
               styleClass="error-label"
               visible="false"
               managed="false"
               StackPane.alignment="BOTTOM_CENTER" />

    </children>

</StackPane>