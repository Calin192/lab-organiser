<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.laborganiser.frontend.shelf.ShelfAddController"
            prefHeight="200.0" prefWidth="300.0">
    <VBox alignment="CENTER"><TextField promptText="Shelf Name" fx:id="shelfName" styleClass="input" maxWidth="300"/>
        <ComboBox promptText="Collection" fx:id="collectionCombobox" styleClass="input" maxWidth="300"/>
        <Button mnemonicParsing="false" text="Add" onAction="#onAddClicked" styleClass="primary-button"/>

    </VBox>

</StackPane>
